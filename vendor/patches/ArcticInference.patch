+# --------------------------------------------------------------------------
+# Basic invariants
+# --------------------------------------------------------------------------
+
+
+class TestPopBasic:
+    def test_pop_zero_is_noop(self):
+        tree = SuffixTree(8, True)
+        tree.extend(0, [1, 2, 3])
+        tree.pop(0, 0)
+        assert tree.check_integrity() == ""
+        assert tree.num_seqs() == 1
+        assert tree.undo_log_length(0) == 3
+
+    def test_pop_without_undo_raises(self):
+        tree = SuffixTree(8)
+        tree.extend(0, [1, 2])
+        with pytest.raises(Exception):
+            tree.pop(0, 1)
+
+    def test_pop_more_than_log_raises(self):
+        tree = SuffixTree(8, True)
+        tree.extend(0, [1, 2, 3])
+        with pytest.raises(Exception):
+            tree.pop(0, 5)
+        # Tree state must be unchanged on failed pop.
+        assert tree.check_integrity() == ""
+        assert tree.undo_log_length(0) == 3
+
+    def test_pop_negative_raises(self):
+        tree = SuffixTree(8, True)
+        tree.extend(0, [1, 2, 3])
+        with pytest.raises(Exception):
+            tree.pop(0, -1)
+
+    def test_pop_unknown_seq_raises(self):
+        tree = SuffixTree(8, True)
+        tree.extend(0, [1, 2])
+        with pytest.raises(Exception):
+            tree.pop(99, 1)
+
+    def test_pop_after_remove_raises(self):
+        tree = SuffixTree(8, True)
+        tree.extend(0, [1, 2, 3])
+        tree.remove(0)
+        with pytest.raises(Exception):
+            tree.pop(0, 1)
+
+    def test_clear_undo_log(self):
+        tree = SuffixTree(8, True)
+        tree.extend(0, [1, 2, 3])
+        assert tree.undo_log_length(0) == 3
+        tree.clear_undo_log()
+        assert tree.undo_log_length(0) == 0
+        # Tree itself unaffected.
+        assert tree.check_integrity() == ""
+        assert tree.num_seqs() == 1
+        with pytest.raises(Exception):
+            tree.pop(0, 1)

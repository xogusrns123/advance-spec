+class TestPopMultiSeq:
+    def test_pop_one_seq_leaves_others_alone(self):
+        tree = SuffixTree(8, True)
+        tree.extend(0, [1, 2, 3])
+        tree.extend(1, [1, 2, 4])     # diverges at depth-2
+        tree.extend(2, [1, 2, 3])     # repeats seq 0's pattern
+        tree.pop(2, 3)
+        assert tree.check_integrity() == ""
+        assert tree.num_seqs() == 2
+
+    def test_appends_to_other_seq_between_extend_and_pop(self):
+        tree = SuffixTree(8, True)
+        tree.extend(0, [1, 2, 3])
+        tree.extend(1, [10, 20])
+        # Begin extend on seq 0; mutate seq 1 in between; pop seq 0.
+        tree.extend(0, [4, 5])
+        tree.extend(1, [30, 40])      # interleave on a different seq
+        tree.pop(0, 2)                # pop the [4, 5] from seq 0
+        assert tree.check_integrity() == ""
+
+    def test_pop_recreated_seq(self):
+        # Pop all of seq 0 → seq disappears → re-extend seq 0 with different
+        # tokens → the tree should be consistent.
+        tree = SuffixTree(8, True)
+        tree.extend(0, [1, 2, 3])
+        tree.pop(0, 3)
+        assert tree.num_seqs() == 0
+        tree.extend(0, [9, 8, 7])
+        assert tree.check_integrity() == ""
+        tree.pop(0, 3)
+        assert tree.check_integrity() == ""
+        assert tree.num_seqs() == 0

+    def test_many_seqs_atomic_temp_blocks(self):
+        # Many seqs, each doing atomic temp-extend+pop cycles, no cross-seq
+        # interleaving inside a temp block. Mirrors the simulator running
+        # extension on many cache_req_ids serially.
+        rng = random.Random(2024)
+        max_depth = 8
+        n_seqs = 16
+        tree = SuffixTree(max_depth, True)

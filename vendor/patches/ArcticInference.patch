+    def test_repeated_extend_pop_on_same_seq_no_state_drift(self):
+        """Stressing pop/re-extend cycles on the same seq must not accumulate
+        residual log entries or tree state. Speculation outputs should be
+        bit-stable across cycles."""
+        tree = SuffixTree(8, True)
+        # Permanent base.
+        tree.extend(0, [1, 2, 3, 1, 2])
+        ctx = np.array([1, 2], dtype=np.int32)
+        baseline = tree.speculate_ndarray(ctx, 8, 4.0, 0.0, 0.0, True)
+        baseline_tokens = list(baseline.token_ids)
+        baseline_score = baseline.score
+
+        for cycle in range(100):
+            tree.extend(0, [9, 8, 7])
+            assert tree.check_integrity() == ""
+            tree.pop(0, 3)
+            assert tree.check_integrity() == ""
+            after = tree.speculate_ndarray(ctx, 8, 4.0, 0.0, 0.0, True)
+            assert list(after.token_ids) == baseline_tokens, (cycle, list(after.token_ids))
+            assert abs(after.score - baseline_score) < 1e-6, (cycle, after.score)
+            assert tree.undo_log_length(0) == 5  # only the permanent appends

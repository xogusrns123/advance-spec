+        ctx = np.array([1, 2], dtype=np.int32)
+        before = cache.speculate("r1", ctx)
+        with cache.temporary_extension("r1", [5]):
+            with cache.temporary_extension("r1", [6, 7]):
+                inside = cache.speculate("r1", ctx)
+                assert isinstance(inside.token_ids, list)
+            # After inner pop, integrity OK.
+            assert cache._global_tree.check_integrity() == ""
+        # After outer pop, integrity OK and output matches.
+        after = cache.speculate("r1", ctx)
+        assert list(after.token_ids) == list(before.token_ids)
+        cache.stop_request("r1")

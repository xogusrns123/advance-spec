+    def test_long_random_single_seq_atomic_cycles(self):
+        # Long, varied single-seq workload to catch cumulative bugs.
+        rng = random.Random(99999)
+        tree = SuffixTree(16, True)
+        permanent = [rng.randint(1, 30) for _ in range(80)]
+        tree.extend(0, permanent)
+        baseline_states = []
+        # Save speculate outputs for varied contexts as the snapshot.
+        ctx_pool = [permanent[i:i + rng.randint(2, 10)]
+                    for i in range(0, len(permanent), 5)]
+        for c in ctx_pool[:15]:
+            if not c:
+                continue
+            d = tree.speculate_ndarray(
+                np.array(c, dtype=np.int32), 16, 4.0, 0.0, 0.0, True)
+            baseline_states.append((c, list(d.token_ids), list(d.parents),
+                                     d.match_len, d.score))
+        # 200 atomic temp cycles.
+        for _ in range(200):
+            k = rng.randint(1, 12)
+            temp = [rng.randint(1, 30) for _ in range(k)]
+            tree.extend(0, temp)
+            assert tree.check_integrity() == ""
+            tree.pop(0, k)
+            assert tree.check_integrity() == ""
+        # Verify all baseline states still match.
+        for c, tids, pids, ml, sc in baseline_states:
+            d = tree.speculate_ndarray(
+                np.array(c, dtype=np.int32), 16, 4.0, 0.0, 0.0, True)
+            assert list(d.token_ids) == tids, (c, list(d.token_ids), tids)
+            assert list(d.parents) == pids
+            assert d.match_len == ml
+            assert abs(d.score - sc) < 1e-6

+class TestPopEdgeCases:
+    """Tighter coverage for boundary conditions and unusual inputs."""
+
+    def test_extend_empty_then_pop_zero(self):
+        tree = SuffixTree(8, True)
+        tree.extend(0, [])  # no-op
+        assert tree.check_integrity() == ""
+        assert tree.num_seqs() == 0
+        # pop(seq, 0) is a no-op even if the seq doesn't exist (popping
+        # zero tokens is unambiguously nothing to do).

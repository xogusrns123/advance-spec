+// === Per-case reverse functions for SuffixTree::pop ===
+//
+// Each reverse_case_* below assumes the tree is currently in the post-
+// original-op state for ONE active-node iteration (per index i). It restores
+// the tree to the pre-iteration state for that single op step. The caller
+// (SuffixTree::pop) is responsible for invoking these in REVERSE order
+// across the per-token op's active_ops list, then handling setup-phase
+// reversal (root count, _seqs.pop_back, active_nodes deque restore).
+
+static void _reverse_case_1a(UndoActiveOp& aop, int seq_id) {
+    Node* node = aop.node;
+    assert(node);
+    // Original mutation: node->length += 1; node->endpoints[seq_id] += 1.
+    node->length -= 1;
+    auto it = node->endpoints.find(seq_id);
+    assert(it != node->endpoints.end());
+    it->second -= 1;
+}
+
+static void _reverse_case_1b(UndoActiveOp& aop, int seq_id) {
+    auto& pl = std::get<UndoCase1B>(aop.payload);
+    (void)pl;  // pl.was_first_child / pl.token informational; see below
+    Node* node = aop.node;
+    Node* new_child = aop.new_active_node;
+    assert(node && new_child);
+
+    // Restore the parent's endpoint that was erased when new_child was added.
+    // Pre-op, node->endpoints[seq_id] was set to seq_len-1, which equals
+    // new_child->ref_idx (new_child was created with that ref_idx).
+    node->endpoints[seq_id] = new_child->ref_idx;
+
+    // new_child has endpoints[seq_id] = seq_len; erase it for clean destruction.
+    new_child->endpoints.erase(seq_id);
+
+    // Detach new_child from node's sibling list. We use _remove_from_siblings
+    // unconditionally — it handles the solo-child case (head/tail both point
+    // to new_child, prev/next are nullptr) AND the case where later, other
+    // seqs added more children to node (so new_child may still be head but
+    // other tails exist). Doing the conditional special-case based on
+    // pl.was_first_child would silently break when interleaved appends alter
+    // node's child count between op and pop.
+    _remove_from_siblings(new_child);
+
+    // Drop new_child from node's children map. The unique_ptr destruction
+    // frees new_child and (transitively) its solo group if still owned.
+    node->children.erase(pl.token);
+}
+
+static void _reverse_case_2a(UndoActiveOp& aop, int seq_id) {
+    auto& pl = std::get<UndoCase2A>(aop.payload);
+    Node* child = aop.new_active_node;
+    Node* node = pl.stashed_node.get();
+    assert(child && node);
+    Node* parent = node->parent;
+    assert(parent);
+
+    // Step 1: Detach child uptr from parent->children[orig_token]. The
+    // original op installed child at this slot (post-op child->token ==
+    // orig_token).
+    auto pit = parent->children.find(pl.orig_token);
+    assert(pit != parent->children.end());
+    std::unique_ptr<Node> child_uptr = std::move(pit->second);
+    parent->children.erase(pl.orig_token);
+
+    // Step 2: Restore most of child's pre-op fields. Defer count and parent
+    // until after the sibling-list swap below:
+    //   - _replace_in_siblings(child, node) asserts old_node->count ==
+    //     new_node->count, which holds while child->count is still
+    //     pl.orig_count (the post-op value).
+    //   - The helper reads old_node->parent (= child->parent) to update
+    //     head/tail_child of THAT parent. Pre-swap, child->parent must
+    //     still be the shared parent (grandparent), not node.
+    child->token = pl.new_token;       // == op.token (pre-op child->token)
+    child->length = 1;
+    child->ref_seq = pl.child_orig_ref_seq;
+    child->ref_idx = pl.child_orig_ref_idx;
+    child->endpoints.erase(seq_id);    // child gained this in the op; remove
+
+    // Step 3: Reinsert node at parent->children[orig_token]. node's own
+    // fields are intact (it was stashed before any modification by the op).
+    parent->children.emplace(pl.orig_token, std::move(pl.stashed_node));
+
+    // Step 4: Reverse the original _replace_in_siblings(node, child). At
+    // this moment child->count == pl.orig_count == node->count (assert
+    // passes), and child->parent is still the shared parent (correct for
+    // the helper's parent-list updates).
+    _replace_in_siblings(child, node);
+
+    // Step 5: Finalize child's count + parent. child becomes node's only
+    // child; its count drops back to its pre-op value.
+    child->count = pl.orig_count - 1;
+    child->parent = node;
+
+    // Step 6: Reinstall child under node->children. The original op's
+    // `release()` (line:412 in append) left node->children[new_token] with
+    // an empty unique_ptr — the key is still present but the slot is empty.
+    // Assign into that slot directly (Int32Map::emplace returns existing on
+    // key collision, so it cannot insert here).
+    {
+        auto cit = node->children.find(pl.new_token);
+        assert(cit != node->children.end() &&
+               cit->second.get() == nullptr);
+        cit->second = std::move(child_uptr);
+    }
+
+    // Step 7: Restore node's head/tail child + child's solo group. Pre-op,
+    // case 2a precondition asserts node->children.size() == 1, so child was
+    // node's only child with its own (single-member) group.
+    node->head_child = node->tail_child = child;
+    child->group.reset(new Group(child));
+    // child->prev_sibling/next_sibling were already nullified by
+    // _replace_in_siblings in Step 4.
+
+    // node->endpoints was not touched by the original op (case 2a deallocates
+    // node wholesale). Nothing to restore there.
+}
+
+static void _reverse_case_2b(UndoActiveOp& aop, int seq_id, int op_token) {
+    auto& pl = std::get<UndoCase2B>(aop.payload);
+    Node* node = aop.node;
+    assert(node);
+    // Case 2b precondition: node->children.size() == 1. Find the single child
+    // regardless of whether the children-map key was changed during the op.
+    assert(node->children.size() == 1);
+    auto cit = node->children.begin();
+    Node* child = cit->second.get();
+    assert(child);
+
+    // Restore children-map key if it changed.
+    if (pl.key_changed) {
+        int new_key = child->token;  // current (post-op) key
+        auto cit2 = node->children.find(new_key);
+        assert(cit2 != node->children.end());
+        std::unique_ptr<Node> child_uptr = std::move(cit2->second);
+        node->children.erase(new_key);
+        node->children.emplace(op_token, std::move(child_uptr));
+    }
+
+    // Restore child geometry.
+    child->length = pl.child_orig_length;
+    child->ref_idx = pl.child_orig_ref_idx;
+    child->token = op_token;  // pre-op value (case 2b precondition)
+
+    // Restore node geometry.
+    node->length = pl.orig_length;
+    auto eit = node->endpoints.find(seq_id);
+    assert(eit != node->endpoints.end());
+    eit->second -= 1;
+    node->ref_seq = pl.orig_ref_seq;
+    node->ref_idx = pl.orig_ref_idx;
+}
+
+// Restore `node` to a specific position in its parent's sibling list. The
+// caller has just removed `node` from the list; this places it back so that
+// node->prev_sibling == prev_sibling_pre AND node->next_sibling ==
+// next_sibling_pre. node->count must already be its pre-op value (which
+// determines group placement).
+static void _reinsert_at_pre_position(Node* node, Node* prev_sibling_pre,
+                                      Node* next_sibling_pre) {
+    assert(node->parent);
+    if (prev_sibling_pre != nullptr) {
+        // Land right after the recorded predecessor.
+        _insert_into_siblings_after(node, prev_sibling_pre);
+    } else if (next_sibling_pre != nullptr) {
+        // Land right before the recorded successor (i.e., become head).
+        _insert_into_siblings_before(node, next_sibling_pre);
+    } else {
+        // Pre-op the node was the only child. parent's head/tail point
+        // back at it; we just need to reset everything.
+        Node* parent = node->parent;
+        assert(parent->head_child == nullptr && parent->tail_child == nullptr);
+        parent->head_child = parent->tail_child = node;
+        node->prev_sibling = node->next_sibling = nullptr;
+        // Fresh group for the solo child.
+        node->group.reset(new Group(node));
+    }
+}
+
+static void _reverse_case_3a(UndoActiveOp& aop, int seq_id) {
+    auto& pl = std::get<UndoCase3A>(aop.payload);

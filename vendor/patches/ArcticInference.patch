+# --------------------------------------------------------------------------
+# Stress: random extend/pop sequences vs. brute rebuild
+# --------------------------------------------------------------------------
+
+
+class TestPopStress:
+    """Stress test under the simulator's actual usage discipline:
+
+      For any seq with a pending temp frame, NO other mutations to ANY seq
+      may happen until that frame is popped. (Equivalent to: temp extend
+      and its matching pop are an atomic block at the seq level.)
+
+    This is the contract the simulator's `_extension_step` honors —
+    `with cache.temporary_extension(req_id, paths[i])` extends, speculates,
+    pops without yielding. Pop reversibility relies on this contract: a
+    seq's per-token undo log records pre-mutation state at op time, but
+    intervening mutations from OTHER seqs may shift counts on shared nodes
+    (case 3a in particular) and invalidate the recorded reverse.
+
+    The stress here exercises:
+      - Multi-seq extend interleaved freely (no temp scopes overlap)
+      - Random temp extend + immediate pop blocks
+      - Per-case mix via random tokens triggering all 6 append paths
+    """
+    @pytest.mark.parametrize("seed", [0, 1, 2, 42, 1337])
+    def test_random_extend_pop_round_trip(self, seed):
+        rng = random.Random(seed)
+        max_depth = 8
+        n_seqs = 4
+        tree = SuffixTree(max_depth, True)
+        canonical = {i: [] for i in range(n_seqs)}
+        token_vocab = list(range(1, 16))
+
+        for step in range(300):
+            seq_id = rng.randrange(n_seqs)
+            mode = rng.random()
+            if mode < 0.5:
+                # Permanent extend.
+                k = rng.randint(1, 4)
+                toks = [rng.choice(token_vocab) for _ in range(k)]
+                tree.extend(seq_id, toks)
+                canonical[seq_id].extend(toks)
+            else:
+                # Atomic temp extend + immediate pop. No interleaving.
+                k = rng.randint(1, 4)
+                toks = [rng.choice(token_vocab) for _ in range(k)]
+                tree.extend(seq_id, toks)
+                tree.pop(seq_id, k)
+            err = tree.check_integrity()
+            assert err == "", (step, err)
+
+        # Build reference from the canonical commits.
+        ref = SuffixTree(max_depth, True)
+        for sid, toks in canonical.items():
+            if toks:
+                ref.extend(sid, toks)
+        assert ref.check_integrity() == ""
+
+        # Speculate score on the same context should match the reference's
+        # score (the *positions* of equal-count children are an internal
+        # detail of the sibling list and are not pop-invariant in general
+        # — but the speculation score, which is a sum over the chosen path's
+        # token probabilities, equals the score of the equivalent path in
+        # the reference because suffix-tree statistics are determined by
+        # the multiset of (seq, suffix-start) pairs, which is the same.)
+        for _ in range(20):
+            sid = rng.randrange(n_seqs)
+            if not canonical[sid]:
+                continue
+            ctx_len = rng.randint(1, min(len(canonical[sid]), max_depth))
+            ctx = np.array(canonical[sid][-ctx_len:], dtype=np.int32)
+            d_tree = tree.speculate_ndarray(ctx, 8, 4.0, 0.0, 0.0, True)
+            d_ref = ref.speculate_ndarray(ctx, 8, 4.0, 0.0, 0.0, True)
+            # match_len is determined purely by the underlying suffix
+            # multiset, so it must match. score is a top-K sum that is
+            # robust to sibling-tie ordering, so we check approximate equality.
+            assert d_tree.match_len == d_ref.match_len, (
+                f"match_len differ on seed={seed} sid={sid} ctx={list(ctx)}: "
+                f"tree={d_tree.match_len} ref={d_ref.match_len}")
+            assert abs(d_tree.score - d_ref.score) < 1e-5, (
+                f"score differ on seed={seed} sid={sid} ctx={list(ctx)}: "
+                f"tree={d_tree.score} ref={d_ref.score}")
+
+    @pytest.mark.parametrize("seed", [7, 13, 99])
+    def test_temp_extension_atomic_block(self, seed):
+        """Targeted test for the simulator's atomic 'with temporary_extension'
+        usage: build base state, then temp-extend / speculate / pop in tight
+        cycles. Each cycle must restore the tree bit-for-bit."""
+        rng = random.Random(seed)
+        max_depth = 8
+        tree = SuffixTree(max_depth, True)
+        # Build a base state of permanent appends across multiple seqs.
+        for sid in range(3):
+            n = rng.randint(5, 15)
+            toks = [rng.randint(1, 10) for _ in range(n)]
+            tree.extend(sid, toks)
+        assert tree.check_integrity() == ""
+
+        # Snapshot speculate output for a probe context BEFORE temp cycles.
+        probe_seq = 0
+        probe_ctx = np.array([1, 2, 3], dtype=np.int32)
+        baseline = tree.speculate_ndarray(
+            probe_ctx, 8, 4.0, 0.0, 0.0, True)
+
+        # Run many temp cycles.
+        for _ in range(50):
+            sid = rng.randrange(3)
+            k = rng.randint(1, 4)
+            toks = [rng.randint(1, 10) for _ in range(k)]
+            tree.extend(sid, toks)
+            # Speculate during the temp scope to confirm the tree is consistent.
+            assert tree.check_integrity() == ""
+            _ = tree.speculate_ndarray(
+                probe_ctx, 8, 4.0, 0.0, 0.0, True)
+            tree.pop(sid, k)
+            assert tree.check_integrity() == ""
+            # Speculate output must match baseline after every pop.
+            after = tree.speculate_ndarray(
+                probe_ctx, 8, 4.0, 0.0, 0.0, True)
+            assert list(after.token_ids) == list(baseline.token_ids)
+            assert list(after.parents) == list(baseline.parents)
+

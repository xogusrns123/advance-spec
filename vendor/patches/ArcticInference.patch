+    def test_simulator_anchor_pattern(self):
+        """Reproduces the simulator's per-anchor flow on a single req_id:
+        many temp extensions back-to-back, each with a different anchor's
+        path. Each speculate during the scope must see the temp tokens; the
+        baseline must hold across all cycles."""
+        cache = SuffixDecodingCache(
+            max_tree_depth=64, max_cached_requests=10, enable_undo=True)
+        cache.start_request("req0", list(range(1, 21)))  # prompt
+        cache.add_active_response("req0", [21, 22, 23])  # decoded prefix
+        ctx = np.array([20, 21, 22], dtype=np.int32)
+        baseline = cache.speculate("req0", ctx)
+        # Simulate 30 anchor extensions.
+        anchor_paths = [
+            [50, 51], [52], [50, 51, 53], [54, 55, 56], [50, 57],
+            [58], [59, 60, 61, 62], [63], [64, 65], [50, 51, 52, 53],
+        ] * 3
+        for i, path in enumerate(anchor_paths):
+            with cache.temporary_extension("req0", path):
+                # Use the temp extension for a speculate.
+                ext_ctx = np.array(
+                    list(range(1, 24)) + path, dtype=np.int32)
+                d = cache.speculate("req0", ext_ctx)
+                assert isinstance(d.token_ids, list)
+                assert cache._global_tree.check_integrity() == ""
+            # After each pop the baseline holds.
+            assert cache._global_tree.check_integrity() == ""
+            assert cache._local_trees["req0"].check_integrity() == ""
+            after = cache.speculate("req0", ctx)
+            assert list(after.token_ids) == list(baseline.token_ids), i
+            assert list(after.parents) == list(baseline.parents), i
+        cache.stop_request("req0")

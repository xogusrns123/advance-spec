+# Speculate semantics
+# --------------------------------------------------------------------------
+
+
+class TestPopSpeculateRoundtrip:
+    def test_speculate_identical_before_and_after(self):
+        """Core invariant: speculate(ctx) returns the same draft before a
+        temp extend+pop pair as after. This is the simulator's use case."""
+        tree = SuffixTree(8, True)
+        tree.extend(0, [1, 2, 3, 4, 1, 2, 3, 5])
+        ctx = np.array([1, 2, 3], dtype=np.int32)
+        before = tree.speculate_ndarray(ctx, 8, 4.0, 0.0, 0.0, True)
+        # Temp extend with hypothetical tokens, then pop.
+        tree.extend(0, [99, 100])
+        tree.pop(0, 2)
+        assert tree.check_integrity() == ""
+        after = tree.speculate_ndarray(ctx, 8, 4.0, 0.0, 0.0, True)
+        assert list(after.token_ids) == list(before.token_ids)
+        assert list(after.parents) == list(before.parents)
+        assert pytest.approx(after.score) == before.score
+

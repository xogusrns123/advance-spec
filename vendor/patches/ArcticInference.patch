+    def test_estimate_memory_stable_after_temp_cycles(self):
+        # Memory should not grow with each temp cycle (no log accumulation
+        # for fully-popped frames). Verify estimate_memory is bounded.
+        tree = SuffixTree(8, True)
+        tree.extend(0, [1, 2, 3])
+        baseline_mem = tree.estimate_memory()
+        for _ in range(100):
+            tree.extend(0, [4, 5, 6])
+            tree.pop(0, 3)
+        assert tree.check_integrity() == ""
+        after_mem = tree.estimate_memory()
+        # Allow some slack for slot retention in Int32Map (tombstones), but
+        # memory should not balloon.
+        assert after_mem <= baseline_mem * 3, (baseline_mem, after_mem)
+        assert tree.undo_log_length(0) == 3  # only the permanent

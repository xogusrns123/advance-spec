+    def test_extend_pop_round_trip(self):
+        cache = SuffixDecodingCache(
+            max_tree_depth=16, max_cached_requests=10, enable_undo=True)
+        cache.start_request("r1", [1, 2, 3])
+        cache.add_active_response("r1", [4, 5])
+        # Speculate snapshot.
+        ctx = np.array([1, 2, 3, 4], dtype=np.int32)
+        before = cache.speculate("r1", ctx)
+        # Temp extension via context manager.
+        with cache.temporary_extension("r1", [99, 100]):
+            # During the scope, the tree has the temp tokens. Speculate
+            # should still work.
+            d_temp = cache.speculate("r1", np.array(
+                [1, 2, 3, 4, 5, 99, 100], dtype=np.int32))
+            assert isinstance(d_temp.token_ids, list)
+            # Both trees must remain integral inside the scope.
+            assert cache._global_tree.check_integrity() == ""
+            assert cache._local_trees["r1"].check_integrity() == ""
+        # After exit, integrity holds AND speculate output matches the
+        # pre-extension snapshot bit-for-bit.
+        assert cache._global_tree.check_integrity() == ""
+        assert cache._local_trees["r1"].check_integrity() == ""
+        after = cache.speculate("r1", ctx)
+        assert list(after.token_ids) == list(before.token_ids)
+        assert list(after.parents) == list(before.parents)
+        cache.stop_request("r1")

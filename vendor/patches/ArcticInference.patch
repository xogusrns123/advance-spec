+
+class TestPopMaxDepthBoundary:
+    def test_pop_long_sequence_with_front_pop(self):
+        """When seq length exceeds max_depth, append() pops the deque front.
+        The popped front node must be restored on reverse."""
+        max_depth = 4
+        tree = SuffixTree(max_depth, True)
+        tokens = list(range(1, 11))  # 10 tokens, exceeds max_depth=4
+        tree.extend(0, tokens)
+        assert tree.check_integrity() == ""
+        tree.pop(0, len(tokens))
+        assert tree.check_integrity() == ""
+        assert tree.num_seqs() == 0
+
+    def test_partial_pop_long_sequence(self):
+        """Pop only a suffix of a long sequence; the remaining log entries
+        must still be poppable later."""
+        tree = SuffixTree(4, True)
+        tokens = [1, 2, 3, 4, 5, 6, 7, 8]
+        tree.extend(0, tokens)
+        # Partially pop, verify integrity, then pop the rest.
+        tree.pop(0, 3)
+        assert tree.check_integrity() == ""
+        assert tree.undo_log_length(0) == 5
+        tree.pop(0, 5)
+        assert tree.check_integrity() == ""
+        assert tree.num_seqs() == 0

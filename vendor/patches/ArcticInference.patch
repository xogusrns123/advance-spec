+    def test_speculate_outputs_bit_stable_across_pop_reextend(self):
+        """For a single seq, extend → snapshot → pop → re-extend(same toks) →
+        speculate outputs must be bit-equal (sibling tie ordering also
+        preserved). This is stronger than 'match_len + score equal' — it
+        confirms the tree structure is restored exactly for the simulator's
+        single-seq pop pattern."""
+        tree = SuffixTree(16, True)
+        permanent = [1, 2, 3, 1, 2, 4, 1, 2, 3]
+        tree.extend(0, permanent)
+        # Snapshot speculate outputs over many contexts.
+        contexts = [
+            [1, 2], [1, 2, 3], [2, 3], [3, 1], [1], [2], [3], [4],
+            [1, 2, 4], [3, 1, 2], [1, 2, 3, 1],
+        ]
+        snaps = []
+        for c in contexts:
+            d = tree.speculate_ndarray(
+                np.array(c, dtype=np.int32), 8, 4.0, 0.0, 0.0, True)
+            snaps.append((list(d.token_ids), list(d.parents),
+                          list(d.probs), d.score, d.match_len))
+        # Now do many extend/pop cycles with various temp tokens.
+        for temp in [[5, 5, 5], [9, 1, 2, 3], [4], [1, 2, 3, 4, 5]]:
+            tree.extend(0, temp)
+            tree.pop(0, len(temp))
+            assert tree.check_integrity() == ""
+            for c, s in zip(contexts, snaps):
+                d = tree.speculate_ndarray(
+                    np.array(c, dtype=np.int32), 8, 4.0, 0.0, 0.0, True)
+                assert list(d.token_ids) == s[0], (c, list(d.token_ids), s[0])
+                assert list(d.parents) == s[1], (c, list(d.parents), s[1])
+                assert d.match_len == s[4], (c, d.match_len, s[4])
+
+    def test_pop_then_remove_then_reextend_clean(self):
+        # Full lifecycle: extend, pop part, remove the seq, then re-create
+        # with new content. Must be clean (no leftover undo state).
+        tree = SuffixTree(8, True)
+        tree.extend(0, [1, 2, 3])
+        tree.pop(0, 1)  # partial
+        assert tree.undo_log_length(0) == 2
+        tree.remove(0)  # drops the rest of seq AND the log
+        assert tree.undo_log_length(0) == 0
+        with pytest.raises(Exception):
+            tree.pop(0, 1)
+        # Re-create.
+        tree.extend(0, [9, 8, 7, 6])
+        assert tree.check_integrity() == ""
+        tree.pop(0, 4)
+        assert tree.check_integrity() == ""
+        assert tree.num_seqs() == 0

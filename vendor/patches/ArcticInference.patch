+        # Atomic temp blocks per seq.
+        for sid in range(n_seqs):
+            for _ in range(20):
+                k = rng.randint(1, 6)
+                temp = [rng.randint(1, 8) for _ in range(k)]
+                tree.extend(sid, temp)
+                assert tree.check_integrity() == ""
+                tree.pop(sid, k)
+                assert tree.check_integrity() == ""

+    def test_speculate_during_temp_scope_sees_temp(self):
+        # Inside the temp extend → speculate → pop block, the speculate must
+        # incorporate the temp tokens (otherwise the simulator's whole
+        # purpose is defeated). Verify match_len grows when temp content
+        # extends a context's matchable suffix.
+        tree = SuffixTree(8, True)
+        # Build a base trajectory.
+        tree.extend(0, [1, 2, 3, 4, 5])
+        ctx_base = np.array([1, 2, 3], dtype=np.int32)
+        d_base = tree.speculate_ndarray(ctx_base, 8, 4.0, 0.0, 0.0, True)
+        base_match = d_base.match_len
+        # Now temp-extend with tokens that make the context have a longer
+        # observable suffix in the tree.
+        tree.extend(0, [9, 1, 2, 3])
+        ctx_temp = np.array([9, 1, 2, 3], dtype=np.int32)
+        d_temp = tree.speculate_ndarray(ctx_temp, 8, 4.0, 0.0, 0.0, True)
+        # The temp-extended tree must yield AT LEAST as much match as the
+        # baseline for the same probe (and typically more for the new ctx).
+        assert d_temp.match_len >= 1
+        tree.pop(0, 4)
+        assert tree.check_integrity() == ""

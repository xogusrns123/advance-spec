+    def test_temp_extends_across_max_depth_boundary(self):
+        # max_depth=4 with permanent length 3 + temp 4 (total 7 > max_depth):
+        # the temp's last appends front-pop active deque; pop must restore.
+        tree = SuffixTree(4, True)
+        tree.extend(0, [1, 2, 3])  # active deque grows: 1, 2, 3 entries
+        ctx = np.array([2], dtype=np.int32)
+        baseline = tree.speculate_ndarray(ctx, 8, 4.0, 0.0, 0.0, True)
+        # Temp extend that spans the max_depth front-pop trigger.
+        tree.extend(0, [4, 5, 6, 7])
+        assert tree.check_integrity() == ""
+        tree.pop(0, 4)
+        assert tree.check_integrity() == ""
+        after = tree.speculate_ndarray(ctx, 8, 4.0, 0.0, 0.0, True)
+        assert list(after.token_ids) == list(baseline.token_ids)
+        assert list(after.parents) == list(baseline.parents)
+        assert abs(after.score - baseline.score) < 1e-6
